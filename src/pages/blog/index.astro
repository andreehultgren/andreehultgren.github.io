---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostList from "../../components/PostList.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Group by year, descending; preserve descending order within each year.
const groups = posts.reduce<Record<string, typeof posts>>((acc, p) => {
  const year = String(p.data.pubDate.getUTCFullYear());
  (acc[year] ??= []).push(p);
  return acc;
}, {});
const years = Object.keys(groups).sort((a, b) => Number(b) - Number(a));

// Continuous numbering across years (01 = newest overall).
let runningIndex = 1;
const orderedGroups = years.map((year) => {
  const entries = groups[year];
  const start = runningIndex;
  runningIndex += entries.length;
  return { year, entries, start };
});
---

<BaseLayout title="Blog" description="All posts.">
  <header class="page-header">
    <p class="eyebrow">Writing</p>
    <h1>Field notes.</h1>
    <p class="sub">Notes, essays, and experiments — newest first.</p>
  </header>

  {
    posts.length === 0 ? (
      <p class="empty">No posts yet.</p>
    ) : (
      <div class="archive">
        {orderedGroups.map(({ year, entries, start }) => (
          <section class="year-group" aria-labelledby={`year-${year}`}>
            <h2 id={`year-${year}`} class="year">
              {year}
            </h2>
            <PostList posts={entries} startIndex={start} />
          </section>
        ))}
      </div>
    )
  }
</BaseLayout>

<style>
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--fg-muted);
    margin: 0 0 var(--space-2);
  }

  .page-header h1 {
    font-size: var(--text-3xl);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .sub {
    color: var(--fg-secondary);
    margin: var(--space-2) 0 0;
    font-size: var(--text-md);
  }

  .archive {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .year-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .year {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--fg);
    margin: 0;
    font-variant-numeric: tabular-nums;
  }

  .empty {
    color: var(--fg-muted);
  }
</style>
