---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Masthead from "../components/Masthead.astro";
import MetaStrip from "../components/MetaStrip.astro";
import NowLine from "../components/NowLine.astro";
import SelectedWork from "../components/SelectedWork.astro";
import PostList from "../components/PostList.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const recent = posts.slice(0, 5);
const total = posts.length;
---

<BaseLayout>
  <Masthead />
  <MetaStrip />
  <NowLine />

  <SelectedWork featuredOnly limit={3} />

  <section class="writing" aria-labelledby="writing-heading">
    <h2 id="writing-heading" class="eyebrow">Writing</h2>
    {
      recent.length === 0 ? (
        <p class="empty">No posts yet.</p>
      ) : (
        <PostList posts={recent} />
      )
    }
    {
      total > recent.length && (
        <p class="more">
          <a href="/blog">See all {total} posts →</a>
        </p>
      )
    }
  </section>
</BaseLayout>

<style>
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--fg-muted);
    margin: 0 0 var(--space-4);
  }

  .empty {
    color: var(--fg-muted);
    margin: 0;
  }

  .more {
    margin: var(--space-6) 0 0;
    font-size: var(--text-sm);
  }

  .more a {
    color: var(--fg-secondary);
    text-decoration: none;
  }

  .more a:hover {
    color: var(--accent);
  }
</style>
