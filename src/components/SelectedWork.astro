---
import { WORK, type WorkEntry } from "../data/site";

interface Props {
  /** Heading label (eyebrow). */
  label?: string;
  /** Limit to featured items (home page). */
  featuredOnly?: boolean;
  /** Hard cap on items. */
  limit?: number;
}

const { label = "Selected work", featuredOnly = false, limit } = Astro.props;

let entries: WorkEntry[] = WORK;
if (featuredOnly) entries = entries.filter((e) => e.featured);
if (limit) entries = entries.slice(0, limit);
---

{
  entries.length > 0 && (
    <section class="work" aria-labelledby="work-heading">
      <h2 id="work-heading" class="eyebrow">
        {label}
      </h2>
      <ul>
        {entries.map((w) => (
          <li>
            {w.href ? (
              <a href={w.href} class="row">
                <span class="name">{w.name}</span>
                <span class="year">{w.year}</span>
                <span class="role">{w.role}</span>
              </a>
            ) : (
              <div class="row plain">
                <span class="name">{w.name}</span>
                <span class="year">{w.year}</span>
                <span class="role">{w.role}</span>
              </div>
            )}
          </li>
        ))}
      </ul>
    </section>
  )
}

<style>
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--fg-muted);
    margin: 0 0 var(--space-4);
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    margin: 0;
    border-bottom: 1px solid var(--border-subtle);
  }

  li:first-child {
    border-top: 1px solid var(--border-subtle);
  }

  li + li {
    margin-top: 0;
  }

  .row {
    display: grid;
    grid-template-columns: 1fr auto;
    column-gap: var(--space-4);
    row-gap: var(--space-1);
    padding: var(--space-4) 0;
    color: var(--fg);
    text-decoration: none;
  }

  a.row:hover .name {
    color: var(--accent);
  }

  .name {
    font-weight: 500;
    font-size: var(--text-base);
    transition: color 120ms ease-out;
  }

  .year {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg-muted);
    font-variant-numeric: tabular-nums;
  }

  .role {
    grid-column: 1 / -1;
    color: var(--fg-secondary);
    font-size: var(--text-sm);
  }
</style>
