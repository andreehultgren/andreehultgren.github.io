---
import { SITE_TITLE } from "../consts";
import ThemeToggle from "./ThemeToggle.astro";

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
const isHome = pathname === "/";
---

<header>
  <nav aria-label="Primary">
    <a href="/" class="brand" aria-current={isActive("/") ? "page" : undefined}>
      <span class="wordmark">{SITE_TITLE}</span>
      {
        isHome && (
          <span class="sub" aria-hidden="true">
            field notes · 2026
          </span>
        )
      }
    </a>
    <div class="links">
      <a href="/blog" aria-current={isActive("/blog") ? "page" : undefined}>
        Blog
      </a>
      <a href="/about" aria-current={isActive("/about") ? "page" : undefined}>
        About
      </a>
    </div>
    <ThemeToggle />
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border-subtle);
  }

  nav {
    max-width: var(--list-width);
    margin: 0 auto;
    padding: var(--space-4) var(--page-pad);
    display: flex;
    gap: var(--space-6);
    align-items: center;
    min-height: 64px;
    line-height: 1.4;
  }

  .links {
    display: flex;
    gap: var(--space-6);
    margin-left: auto;
  }

  nav a {
    color: var(--fg);
    text-decoration: none;
    font-weight: 500;
    font-size: var(--text-base);
  }

  nav a:hover {
    color: var(--accent);
  }

  nav a:hover .sub {
    color: var(--fg-muted);
  }

  nav a[aria-current="page"] .wordmark,
  .links a[aria-current="page"] {
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .brand {
    display: flex;
    flex-direction: column;
    gap: 2px;
    line-height: 1.1;
  }

  .wordmark {
    font-weight: 500;
  }

  .sub {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--fg-muted);
  }
</style>
