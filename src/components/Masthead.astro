---
import { MASTHEAD } from "../data/site";
---

<section class="masthead">
  <p>{MASTHEAD}</p>
</section>

<style>
  .masthead {
    padding-top: var(--space-8);
  }

  .masthead p {
    margin: 0;
    font-size: var(--text-xl);
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--fg);
    max-width: 38ch;
  }

  @media (min-width: 720px) {
    .masthead p {
      font-size: var(--text-2xl);
    }
  }
</style>
