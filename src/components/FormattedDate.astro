---
// Date formatted per design.md §6 post-list spec: "13 May 26" — short month,
// two-digit year, monospace, tabular figures. Caller controls font via class.
interface Props {
  date: Date;
  /** "short" → "13 May 26"; "long" → "13 May 2026". Default short. */
  variant?: "short" | "long";
  class?: string;
}

const { date, variant = "short", class: className } = Astro.props;

const year =
  variant === "short"
    ? String(date.getUTCFullYear()).slice(-2)
    : String(date.getUTCFullYear());

const month = date.toLocaleDateString("en-GB", {
  month: "short",
  timeZone: "UTC",
});
const day = String(date.getUTCDate()).padStart(2, "0");

const display = `${day} ${month} ${year}`;
---

<time datetime={date.toISOString()} class:list={["tabular", className]}>
  {display}
</time>

<style>
  time {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
  }
</style>
