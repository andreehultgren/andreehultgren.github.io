---
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";

interface NavLink {
  title: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  heroImage?: string;
  kind?: "NOTE" | "ESSAY" | "FIELD NOTE";
  dropCap?: boolean;
  wordCount?: number;
  prev?: NavLink | null;
  next?: NavLink | null;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  heroImage,
  kind = "NOTE",
  dropCap = false,
  wordCount = 0,
  prev = null,
  next = null,
} = Astro.props;

// Reading time per design §6: ~200 wpm, shown only when ≥2 min.
const readMinutes = Math.max(1, Math.round(wordCount / 200));
const showReadTime = readMinutes >= 2;
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  prose
>
  <article>
    <p class="back">
      <a href="/blog">← Blog</a>
    </p>

    <header class="post-header">
      <p class="eyebrow">{kind}</p>
      <h1>{title}</h1>
      <p class="meta">
        <FormattedDate date={pubDate} variant="long" />
        {showReadTime && <span> · {readMinutes} min read</span>}
        {
          updatedDate && (
            <span>
              {" "}· updated <FormattedDate date={updatedDate} variant="long" />
            </span>
          )
        }
      </p>
      {
        tags.length > 0 && (
          <p class="tags">
            {tags.map((t) => (
              <span class="tag">{t}</span>
            ))}
          </p>
        )
      }
      {heroImage && <img src={heroImage} alt="" class="hero" />}
    </header>

    <div class={`prose${dropCap ? " has-dropcap" : ""}`}>
      <slot />
    </div>

    <p class="end-mark" aria-hidden="true">❡</p>

    {
      (prev || next) && (
        <nav class="post-nav" aria-label="More posts">
          <div class="prev">
            {prev && (
              <a href={prev.href}>
                <span class="dir">← Previous</span>
                <span class="title-link">{prev.title}</span>
              </a>
            )}
          </div>
          <div class="next">
            {next && (
              <a href={next.href}>
                <span class="dir">Next →</span>
                <span class="title-link">{next.title}</span>
              </a>
            )}
          </div>
        </nav>
      )
    }
  </article>
</BaseLayout>

<style>
  article > * + * {
    margin-top: 0;
  }

  .back {
    font-size: var(--text-sm);
    margin: 0 0 var(--space-8);
  }

  .back a {
    color: var(--fg-muted);
    text-decoration: none;
  }

  .back a:hover {
    color: var(--accent);
  }

  .post-header {
    margin-top: var(--space-12);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--fg-muted);
    margin: 0 0 var(--space-3);
  }

  .post-header h1 {
    font-size: var(--text-3xl);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .meta {
    margin: var(--space-4) 0 0;
    font-size: var(--text-sm);
    color: var(--fg-muted);
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
  }

  .tags {
    margin: var(--space-3) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .tag {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--fg-muted);
  }

  .hero {
    width: 100%;
    border-radius: 6px;
    margin: var(--space-8) 0;
  }

  .prose {
    margin-top: var(--space-12);
  }

  /* Lead paragraph — first <p> in the rendered Markdown. Slight scale lift. */
  .prose :global(> p:first-of-type) {
    font-size: var(--text-md);
    color: var(--fg);
    line-height: 1.6;
  }

  /* Drop cap (opt-in via frontmatter). */
  .prose.has-dropcap :global(> p:first-of-type::first-letter) {
    float: left;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 3.6em;
    line-height: 0.9;
    margin: 4px var(--space-3) 0 0;
    color: var(--fg);
  }

  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol),
  .prose :global(blockquote),
  .prose :global(pre),
  .prose :global(figure),
  .prose :global(table) {
    margin-top: 0;
    margin-bottom: 0;
  }

  .prose :global(> * + *) {
    margin-top: var(--space-6);
  }

  .prose :global(h2) {
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    font-size: var(--text-xl);
  }

  .prose :global(h3) {
    margin-top: var(--space-8);
    margin-bottom: var(--space-2);
    font-size: var(--text-lg);
  }

  .prose :global(img),
  .prose :global(figure) {
    margin-top: var(--space-8);
    margin-bottom: var(--space-8);
    border-radius: 6px;
  }

  .prose :global(figcaption) {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    text-align: center;
    margin-top: var(--space-2);
  }

  .prose :global(hr) {
    margin: var(--space-12) 0;
    border: 0;
    border-top: 1px solid var(--border-subtle);
  }

  .end-mark {
    margin: var(--space-12) 0 0;
    text-align: center;
    color: var(--fg-muted);
    font-size: var(--text-lg);
    line-height: 1;
  }

  .post-nav {
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--border-subtle);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  .post-nav .prev,
  .post-nav .next {
    min-width: 0;
  }

  .post-nav .next {
    text-align: right;
  }

  .post-nav a {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    color: var(--fg);
    text-decoration: none;
  }

  .post-nav .dir {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--fg-muted);
  }

  .post-nav .title-link {
    font-weight: 500;
    font-size: var(--text-base);
    transition: color 120ms ease-out;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .post-nav a:hover .title-link {
    color: var(--accent);
  }

  @media (max-width: 540px) {
    .post-nav {
      grid-template-columns: 1fr;
    }
    .post-nav .next {
      text-align: left;
    }
  }
</style>
