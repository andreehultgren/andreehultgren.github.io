---
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** Constrain main to prose measure (65ch). Used on post pages. */
  prose?: boolean;
}

const { title, description, image, prose = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body>
    <a href="#content" class="skip-link">Skip to content</a>
    <Header />
    <main id="content" class={prose ? "prose-page" : undefined}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
